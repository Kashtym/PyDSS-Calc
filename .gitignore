.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Local environment/config
.env
.env.*

# Generated project outputs (reports/plots)
*_report.txt
*_tcc.png

# Keep only examples in projects/
projects/*
!projects/examples/
!projects/examples/**
